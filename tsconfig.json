{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "noEmit": true,
    "checkJs": false,
    "allowJs": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "**/*.js",
    "**/*.jsx"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
